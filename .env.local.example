# Required: TWIN node URL
TWIN_NODE_URL=https://kitsune.staging.twinnodes.com

# Optional: service-account credentials.
# When set, the app auto-authenticates server-side and visitors don't need to
# log in. Leave blank to force the manual login flow at /twin-showcase/login.
TWIN_NODE_SERVICE_EMAIL=admin@node
TWIN_NODE_SERVICE_PASSWORD=

NEXT_TELEMETRY_DISABLED=1
